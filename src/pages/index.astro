---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../assets/seyed-amir-alavi.jpeg";
import { SOCIAL_LINKS } from "../consts";
import SocialIcon from "../components/SocialIcon.astro";

const education = [
  {
    degree: "PhD in Electronic Engineering",
    school: "Queen Mary University of London (QMUL)",
    place: "London, United Kingdom",
    year: "2021",
  },
  {
    degree: "MSc in Control Systems Engineering",
    school: "Shahid Beheshti University (SBU)",
    place: "Tehran, Iran",
    year: "2017",
  },
  {
    degree: "BSc in Electrical Engineering",
    school: "Power and Water University of Technology (PWUT)",
    place: "Tehran, Iran",
    year: "2013",
  },
];
---

<BaseLayout>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-text">
      <p class="eyebrow reveal-hero" style="--i: 0">Engineer &amp; Artist</p>
      <h1 class="reveal-hero" style="--i: 1">
        Hi, I'm <span class="name-gradient">Amir Alavi</span>
      </h1>
      <p class="lead reveal-hero" style="--i: 2">
        Embedded systems engineer working across the Internet of Things (IoT),
        industrial control systems, and communication networks. I write about
        IoT, control systems, and embedded software development based on my
        latest research and hands-on experience.
      </p>
      <div class="hero-actions reveal-hero" style="--i: 3">
        <a class="btn btn-primary" href="/blog">Read the Blog</a>
        <a class="btn btn-ghost" href="/contact">Get in Touch</a>
      </div>
      <div class="hero-social reveal-hero" style="--i: 4">
        {
          SOCIAL_LINKS.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
            >
              <SocialIcon icon={s.icon} />
            </a>
          ))
        }
      </div>
    </div>
    <div class="hero-photo reveal-hero" style="--i: 2">
      <div class="photo-halo" aria-hidden="true"></div>
      <Image
        src={profile}
        alt="Amir Alavi"
        width={320}
        height={320}
        loading="eager"
      />
    </div>
  </section>

  <section class="about prose reveal">
    <h2>About Me</h2>
    <p>
      As an embedded systems engineer, I have designed different types of
      embedded systems in several areas such as the Internet of Things (IoT),
      industrial control systems, and communication networks. I try to employ
      the latest technologies for software and hardware development, from
      embedded Linux to different real-time operating systems (RTOSs), and agile
      software development processes. Model-based embedded system design and
      implementation is my main expertise, which I have done during the last
      several years. During my doctoral study at Queen Mary University of London
      (QMUL), I worked on the development of multi-agent embedded systems for
      distributed control power systems, which operate over IoT wireless
      communications protocols with different objectives. I have published
      several papers in high impact engineering journals and presented my
      research in top rank conferences around the world.
    </p>
  </section>

  <section class="education reveal">
    <h2>Education</h2>
    <div class="timeline">
      {
        education.map((e, i) => (
          <div class="edu-card card reveal" style={`--i: ${i}`}>
            <div class="edu-year">{e.year}</div>
            <div>
              <h3>{e.degree}</h3>
              <p>
                {e.school}
                <br />
                <span class="muted">{e.place}</span>
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2.5rem;
    padding: 1rem 0 2.5rem;
  }

  /* Soft animated gradient glow behind the hero */
  .hero-bg {
    position: absolute;
    top: -30%;
    left: 50%;
    width: 120%;
    height: 160%;
    transform: translateX(-50%);
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(
        40% 40% at 20% 30%,
        color-mix(in srgb, var(--accent) 22%, transparent),
        transparent 70%
      ),
      radial-gradient(
        35% 35% at 80% 20%,
        color-mix(in srgb, var(--accent-hover) 20%, transparent),
        transparent 70%
      );
    filter: blur(20px);
    opacity: 0.7;
    animation: drift 14s ease-in-out infinite alternate;
  }

  @keyframes drift {
    0% {
      transform: translateX(-50%) translateY(0) scale(1);
    }
    100% {
      transform: translateX(-50%) translateY(-16px) scale(1.08);
    }
  }

  /* Animated gradient name */
  .name-gradient {
    background: linear-gradient(
      100deg,
      var(--accent),
      var(--accent-hover),
      var(--accent)
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 6s linear infinite;
  }

  @keyframes shine {
    to {
      background-position: 200% center;
    }
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem;
  }
  .lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 40ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 1.25rem;
  }
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.25rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease,
      border-color 0.15s ease, color 0.15s ease;
    border: 1px solid transparent;
    overflow: hidden;
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    color: #fff;
  }
  .btn-primary:hover {
    box-shadow: 0 10px 24px -8px color-mix(in srgb, var(--accent) 70%, transparent);
  }
  /* Light sweep across the primary button on hover */
  .btn-primary::after {
    content: "";
    position: absolute;
    top: 0;
    left: -120%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      100deg,
      transparent,
      rgba(255, 255, 255, 0.35),
      transparent
    );
    transform: skewX(-20deg);
  }
  .btn-primary:hover::after {
    animation: sweep 0.7s ease;
  }
  @keyframes sweep {
    to {
      left: 130%;
    }
  }
  .btn-ghost {
    background: var(--bg-soft);
    color: var(--heading);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-social {
    display: flex;
    gap: 0.5rem;
  }
  .hero-social a {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .hero-social a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .hero-photo {
    position: relative;
    display: grid;
    place-items: center;
  }
  .hero-photo :global(img) {
    position: relative;
    border-radius: 50%;
    border: 4px solid var(--border);
    box-shadow: var(--shadow);
    object-fit: cover;
    animation: float 6s ease-in-out infinite;
    transition: transform 0.3s ease;
  }
  .hero-photo:hover :global(img) {
    transform: scale(1.03);
  }
  .photo-halo {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      var(--accent),
      var(--accent-hover),
      var(--accent),
      var(--accent-hover),
      var(--accent)
    );
    filter: blur(16px);
    opacity: 0.55;
    z-index: 0;
    animation: spin 12s linear infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .about {
    margin-top: 1rem;
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }
  .edu-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    align-items: flex-start;
  }
  .edu-year {
    font-weight: 800;
    color: var(--accent);
    font-size: 1.1rem;
    min-width: 3.5rem;
  }
  .edu-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
  }
  .edu-card p {
    margin: 0;
  }
  .muted {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Hero entrance: staggered fade + rise, plays on load */
  .reveal-hero {
    opacity: 0;
    transform: translateY(16px);
    animation: rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i, 0) * 120ms);
  }

  /* Scroll reveal: hidden until .in-view is added by the observer */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i, 0) * 90ms);
  }
  .reveal.in-view {
    opacity: 1;
    transform: none;
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Respect users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-bg,
    .photo-halo,
    .name-gradient,
    .hero-photo :global(img) {
      animation: none !important;
    }
    .reveal-hero,
    .reveal {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
      transition: none !important;
    }
    .name-gradient {
      background-position: 0 center;
    }
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }
    .lead {
      max-width: none;
    }
    .hero-actions,
    .hero-social {
      justify-content: center;
    }
    .hero-photo {
      order: -1;
    }
    .hero-photo :global(img) {
      width: 180px;
      height: 180px;
    }
  }
</style>

<script>
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;
  const items = document.querySelectorAll<HTMLElement>(
    ".reveal:not(.reveal-hero)"
  );

  if (prefersReduced || !("IntersectionObserver" in window)) {
    items.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -10% 0px" }
    );
    items.forEach((el) => observer.observe(el));
  }
</script>

